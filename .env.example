# Copy to `.env` and fill in `PRIVATE_KEY` only (deployer). Other values below are a
# consistent dev set: PK mint matches `test/test-vectors/token_42.json` (same as tests).

# --- Broadcast (you fill) ---
PRIVATE_KEY=

# --- RPC ---
RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# --- GhostVault: mint BLS public key (G2 on BN254), four Fp limbs ---
# These are not “image” in the photo sense: *_IMAG / *_REAL are the imaginary and real
# Fp components of the G2 point’s X and Y in Fp² (how the curve / precompile encodes G2).
# Order matches `GhostVaultScript` and tests: X_imag, X_real, Y_imag, Y_real.
PK_MINT_X_IMAG=0x08ff1e1c2b9f57f077a6533628a0b88aca28691252fa44fb43035b077791d4a2
PK_MINT_X_REAL=0x289bc1a5bb8e3e52e8ba7d8412cc177cacfb84a212fa2cac9103ec48914f4f5b
PK_MINT_Y_IMAG=0x229c66f806da97fcfb019970fc8ea43bb98a15cf19141678ba75f83432cb7e01
PK_MINT_Y_REAL=0x1386afd2a4e67ade3894a75e70264a39cb7e6c0238739a4bbfada266ef134023

# --- Mint authority (EVM `announce` signer) — generated for this example ---
MINT_AUTHORITY=0x0A85fBD5F4b8FBFa3628581C3b47502705016004
