# Copy to `.env` and fill in `PRIVATE_KEY` only (deployer).
#
# Mint BLS (off-chain): `BLS_MINT_ADDRESS=0x63871d1d66be410D20e91100745ccb158DEd8DbF`
# is an application id / label — the contract only uses the G2 limbs below.
# Those limbs are sk·G2 for your mint scalar (same math as `generate_vectors.py`);
# do not commit `BLS_MINT_PRIVATE_KEY`; keep it in local `.env` or a secrets store.

# --- Broadcast (you fill) ---
PRIVATE_KEY=

# --- RPC ---
RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# --- GhostVault: mint BLS public key (G2 on BN254), four Fp limbs ---
# *_IMAG / *_REAL = imaginary and real Fp parts of G2 X and Y (Fp² encoding).
# Order: X_imag, X_real, Y_imag, Y_real (matches `GhostVaultScript` + tests).
PK_MINT_X_IMAG=0x0196339d3ec3871b103bf2e021b8956d7067c39ddf4c04aeccff6a7f0b4d97dc
PK_MINT_X_REAL=0x03babf2d6fb6f85345ee4c4d918b35e0c0dd98d0a1d46c34b9db6eb0ce6095e1
PK_MINT_Y_IMAG=0x1d9bec7624f60a34a8ff49f501f9f1cd8ea20019459770c196b1cb5a82aaee83
PK_MINT_Y_REAL=0x2348d14f52c550a5bfa0932d7ce0601ca73c576c216ec469cd2d539feaf5232b

# --- Mint authority (EVM `announce` signer) — generated for this example ---
MINT_AUTHORITY=0x0A85fBD5F4b8FBFa3628581C3b47502705016004
