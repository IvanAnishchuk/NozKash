# Optional (dev): if set, used as masterSeed — no personal_sign prompt.
# Without this, a one-time signature is requested on wallet connect; seed lives in RAM only.
# VITE_NOZK_MASTER_SEED_HEX=

# Deployed NozkVault contract address (required for mainnet/testnets other than the code default).
# VITE_NOZK_VAULT_ADDRESS=0x...
# First block containing the contract — hex (`0xa0948a`) or decimal (`10523786`).
# Update on redeploy to avoid scanning the entire chain.
# VITE_NOZK_VAULT_SCAN_FROM_BLOCK_HEX=0xa0948a

# --- Ethereum Sepolia (testing defaults; no secrets here — safe to copy into .env) ---
# Chain id 11155111 — must match RPC + deployed NozkVault.
VITE_CHAIN_ID=0xaa36a7
# MetaMask "Network name" when adding the chain:
VITE_CHAIN_NAME=Sepolia
# In-app label when the wallet is on the target chain:
VITE_CHAIN_DISPLAY_NAME=Sepolia
# Badge "Sepolia · testnet" on deposit / redeem (optional; omit to drop the tag):
VITE_WALLET_NETWORK_TAG=testnet
VITE_BLOCK_EXPLORER_URL=https://sepolia.etherscan.io
VITE_NATIVE_CURRENCY_SYMBOL=ETH
VITE_NATIVE_CURRENCY_NAME=Ether
VITE_NATIVE_CURRENCY_DECIMALS=18

# HTTP JSON-RPC + WebSocket (same network). WS is optional: if unset, vault activity uses HTTP only
# (see `getChainWsRpcUrl` in `nozkVaultLiveActivity.ts` — also tries wss://<host> for publicnode HTTPS URLs).
VITE_PUBLIC_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
# Explicit WS (recommended for live logs if auto-derivation fails):
# VITE_PUBLIC_WS_RPC_URL=wss://ethereum-sepolia-rpc.publicnode.com
# Alias for the same vars (optional):
# VITE_ETHEREUM_RPC_URL=
# VITE_ETHEREUM_WS_RPC_URL=

# Public/free tier: JSON-RPC queue + minimum gap between requests.
# VITE_PUBLIC_RPC_MIN_GAP_MS=150
# VITE_PUBLIC_RPC_MAX_RETRIES=4

# Vault scanning (defaults tuned for public RPC: burst 5, pause 7500ms):
# VITE_NOZK_VAULT_RPC_BURST=5
# VITE_NOZK_VAULT_RPC_PAUSE_MS=7500
# VITE_NOZK_VAULT_SCAN_CACHE_MS=60000
# VITE_NOZK_VAULT_RPC_POLL_MS=15000
# Token indices per batch (default 5). E.g., 3 reduces calls per batch.
# VITE_NOZK_VAULT_TOKEN_BATCH_SIZE=3
# Minimum index for new deposits (default 2; keeps 0-1 free if applicable).
# VITE_NOZK_VAULT_MIN_NEW_DEPOSIT_TOKEN_INDEX=2

# Redeem (optional): before the first "Start redeem", restricts which account sees the button (prepare).
# After saving the draft, `prepareAccount` in localStorage is used instead.
# VITE_NOZK_REDEEM_PREPARE_ACCOUNT=
# Redeem (optional): only this account sees "Redeem here" (the account that signs the tx).
# VITE_NOZK_REDEEM_EXECUTOR_ACCOUNT=

# Debug NozkVault: console output for deposit + activity + redeem (also active in `npm run dev` without this).
# Do NOT use in production except for intentional staging builds.
# VITE_NOZK_DEBUG=true

# Non-root deployment path (e.g., GitHub Pages subpath).
# VITE_BASE_PATH=/nozkash/

# Max batches for scanning token indices / next deposit (default 128; max 10000).
# VITE_NOZK_VAULT_MAX_BATCHES=32
